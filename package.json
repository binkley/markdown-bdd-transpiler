{
  "name": "@binkley/markdown-bdd-transpiler",
  "version": "0.2.0",
  "description": "An AI-augmented BDD testing framework that transpiles Markdown user journeys into Playwright tests.",
  "keywords": [
    "bdd",
    "testing",
    "playwright",
    "markdown",
    "gemini",
    "genai",
    "e2e"
  ],
  "author": "B. K. Oxley (binkley) <binkley@alumni.rice.edu>",
  "homepage": "https://github.com/binkley/markdown-bdd-transpiler#readme",
  "bugs": {
    "url": "https://github.com/binkley/markdown-bdd-transpiler/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/binkley/markdown-bdd-transpiler.git"
  },
  "bin": {
    "markdown-bdd": "./dist/transpile.js"
  },
  "exports": {
    "./framework": "./dist/framework/standard-ui-steps.js"
  },
  "files": [
    "dist",
    "manifest.json",
    "schema.json"
  ],
  "dependencies": {
    "@google/genai": "^2.5.0",
    "@types/unist": "^3.0.3",
    "ai": "^6.0.191",
    "mri": "^1.2.0",
    "p-limit": "^7.3.0",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/google": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "@playwright/test": "^1.60.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/mdast": "^4.0.4",
    "@types/p-limit": "^2.1.0",
    "eslint": "^10.4.0",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "shellcheck": "^3.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "scripts": {
    "help": "node scripts/help.js",
    "?": "npm run help",
    "// --- 🛠️ BUILD & DEV --- //": "",
    "?build": "echo \"Compile the TypeScript codebase to the dist/ directory\"",
    "build": "tsc",
    "postbuild": "tsx scripts/generate-schema.js",
    "?demo": "echo \"Run the demo application locally\"",
    "demo": "tsx demo-app.ts",
    "?transpile": "echo \"Execute the compiled transpiler binary\"",
    "transpile": "node ./dist/transpile.js",
    "// --- 🧹 LINT & FORMAT --- //": "",
    "?format": "echo \"Format all files using Prettier\"",
    "format": "prettier --write .",
    "?lint": "echo \"Run both ESLint (JS/TS) and Shellcheck (Bash)\"",
    "lint": "npm run lint:js && npm run lint:sh",
    "lint:js": "eslint .",
    "lint:sh": "shellcheck scripts/*.sh",
    "?type-check": "echo \"Verify TypeScript type safety without emitting files\"",
    "type-check": "tsc --noEmit",
    "// --- 🧪 TESTING --- //": "",
    "?test": "echo \"Run both fast unit tests and the full E2E suite\"",
    "test": "npm run test:unit && npm run test:e2e",
    "?test:unit": "echo \"Run fast native Node.js unit tests with coverage\"",
    "test:unit": "node --experimental-test-coverage --test-coverage-lines=97 --test-coverage-functions=95 --import tsx --test 'src/**/*.spec.ts'",
    "?test:e2e": "echo \"Boot Docker and run the full Playwright integration suite\"",
    "test:e2e": "./scripts/test-e2e.sh",
    "test:playwright": "playwright test",
    "pretest:playwright": "npm run build && npm run transpile",
    "// --- ⚙️ MAINTAINER OPS --- //": "",
    "prepare": "husky",
    "?profile": "echo \"Benchmark the execution time of any arbitrary NPM command\"",
    "profile": "./scripts/run-and-time.sh",
    "?profile:e2e": "echo \"Benchmark the Dockerized E2E test pipeline\"",
    "profile:e2e": "npm run profile -- profile-e2e npm run test:e2e",
    "?release": "echo \"Trigger a semantic version bump and NPM publish (Maintainers only)\"",
    "release": "./scripts/release.sh",
    "?validate:commit": "echo \"Run the fast pre-commit pipeline (skips Docker tests)\"",
    "validate:commit": "./scripts/validate.sh --commit",
    "?validate:push": "echo \"Run the strict pre-push pipeline (includes E2E Docker tests)\"",
    "validate:push": "./scripts/validate.sh --push"
  }
}

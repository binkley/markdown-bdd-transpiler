  },
  "files": [
    "dist",
    "manifest.json"
  ],
  "dependencies": {
    "@google/genai": "^2.4.0",
    "marked": "^18.0.4",
    "mri": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "eslint": "^10.4.0",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "scripts": {
    "build": "tsc",
    "demo": "tsx demo-app.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "postinstall": "playwright install chromium",
    "prepare": "husky",
    "pretest": "npm run build && node ./dist/transpile.js",
    "test": "playwright test",
    "type-check": "tsc --noEmit"

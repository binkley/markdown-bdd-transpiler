{
  "name": "@binkley/bdd-markdown-transpiler",
  "version": "0.0.5",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/binkley/markdown-bdd-transpiler.git"
  },
  "bin": {
    "markdown-bdd": "./dist/transpile.js"
  },
  "exports": {

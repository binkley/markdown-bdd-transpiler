FROM node:22-alpine

WORKDIR /app

# Cache layer: install ALL dependencies (including devDeps like typescript)
COPY package*.json ./
RUN npm ci --ignore-scripts

# Copy the demo app and config
COPY demo-app.ts tsconfig.demo.json ./

# Compile the TypeScript to JavaScript using tsconfig.demo.json
RUN npx tsc --project tsconfig.demo.json

EXPOSE 5173

# Run the compiled JS file natively
CMD ["node", "demo-app.js"]

FROM node:22-alpine

WORKDIR /app

# Cache layer: install ALL dependencies (including devDeps like typescript)
COPY package*.json ./
RUN npm ci --ignore-scripts

# Copy the demo app and config
COPY demo-app.ts tsconfig.json ./

# Compile the TypeScript to JavaScript
RUN npx tsc demo-app.ts --outDir . --module NodeNext --moduleResolution NodeNext

EXPOSE 5173

# Run the compiled JS file natively
CMD ["node", "demo-app.js"]
